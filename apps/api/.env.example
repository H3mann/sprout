# Supabase (Sprout)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-key

# Supabase (Realm)
REALM_SUPABASE_URL=https://your-realm-project.supabase.co
REALM_SUPABASE_ANON_KEY=your-realm-anon-key
REALM_SUPABASE_SERVICE_KEY=your-realm-service-key

# Perplexity AI (for pediatric research search)
PERPLEXITY_API_KEY=your-perplexity-api-key

# Real Estate APIs (free tiers)
CENSUS_API_KEY=your-census-api-key
FRED_API_KEY=your-fred-api-key
# CORS — set to your frontend URL in production (comma-separated for multiple)
CORS_ORIGIN=http://localhost:4200,http://localhost:4201

# Server port
PORT=3333
